// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-1.1.x"]
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum DeliveryOrderStatus {
  PENDING
  ASSIGNED
  DELIVERED
  FAILED
}

enum DeliveryRunStatus {
  IN_PROGRESS
  COMPLETED
}

enum DeliveryStopStatus {
  PENDING
  COMPLETED
  FAILED
}

model DeliveryCustomer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  address   String   @db.VarChar(500)
  createdAt DateTime @default(now())

  orders DeliveryOrder[]
}

model DeliveryDriver {
  id        Int      @id @default(autoincrement())
  uid       String   @unique
  name      String
  phone     String?
  createdAt DateTime @default(now())

  runs DeliveryRun[]
}

model DeliveryOrder {
  id     Int                 @id @default(autoincrement())
  status DeliveryOrderStatus @default(PENDING)

  customerId Int
  customer   DeliveryCustomer @relation(fields: [customerId], references: [id])

  deliveryRunId Int?
  deliveryRun   DeliveryRun? @relation(fields: [deliveryRunId], references: [id])

  stop  DeliveryStop?
  items DeliveryOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([deliveryRunId])
  @@index([customerId])
}

model DeliveryOrderItem {
  id       Int    @id @default(autoincrement())
  name     String
  quantity Int

  orderId Int
  order   DeliveryOrder @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model DeliveryRun {
  id     Int               @id @default(autoincrement())
  status DeliveryRunStatus @default(IN_PROGRESS)

  driverId Int
  driver   DeliveryDriver @relation(fields: [driverId], references: [id])

  nextSequence Int @default(1)

  orders DeliveryOrder[]
  stops  DeliveryStop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId, status])
}

model DeliveryStop {
  id       Int                @id @default(autoincrement())
  sequence Int
  status   DeliveryStopStatus @default(PENDING)

  proofPhotoUrl     String?
  proofSignatureUrl String?
  failureReason     String?
  resolvedAt        DateTime?

  // 1-1 with DeliveryOrder. Hard guarantee: an order can be assigned at most once.
  // Even if app-level locks fail, a second INSERT for the same orderId raises P2002.
  orderId Int           @unique
  order   DeliveryOrder @relation(fields: [orderId], references: [id])

  runId Int
  run   DeliveryRun @relation(fields: [runId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Safety net for sequencing: even if two assigns somehow read the same nextSequence,
  // the second INSERT will fail with P2002.
  @@unique([runId, sequence])
  @@index([runId, status])
}
