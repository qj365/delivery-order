{
  "name": "fulfillment-backend",
  "version": "0.0.1",
  "main": "src/index.js",
  "private": true,
  "scripts": {
    "generate": "pnpm db:generate && pnpm doc:generate && pnpm api:generate && pnpm format",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "doc:generate": "pnpm tsoa && ts-node -r tsconfig-paths/register scripts/correct-openapi.ts",
    "api:generate": "ts-node -r tsconfig-paths/register scripts/gen-client/index.ts",
    "build": "tsc",
    "tsoa": "tsoa spec-and-routes",
    "dev": "nodemon -r tsconfig-paths/register ./src/index.ts",
    "lint": "biome check --no-errors-on-unmatched . && cspell lint .",
    "format": "biome check --write --no-errors-on-unmatched ."
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@commitlint/types": "^19.5.0",
    "@types/body-parser": "^1.19.5",
    "@types/config": "^3.3.5",
    "@types/cors": "^2.8.17",
    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/mime": "^3.0.0",
    "@types/node": "^18.19.67",
    "@types/node-fetch": "^2.6.12",
    "@types/swagger-ui-express": "^4.1.7",
    "axios": "^1.7.8",
    "cspell": "^8.16.1",
    "exceljs": "^4.4.0",
    "lefthook": "^1.8.4",
    "nodemon": "^2.0.22",
    "openapi-types": "^12.1.3",
    "openapi-typescript-codegen": "latest",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.701.0",
    "@aws-sdk/s3-request-presigner": "^3.701.0",
    "@prisma/client": "^6.0.0",
    "@tsoa/runtime": "^6.5.1",
    "axios": "^1.7.8",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "firebase": "^11.3.1",
    "firebase-admin": "^12.7.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.4.1",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "mime": "^3.0.0",
    "moment-timezone": "^0.5.46",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.7.0",
    "pino": "^8.21.0",
    "pino-http": "^8.6.1",
    "pino-pretty": "^10.3.1",
    "prisma": "^6.0.0",
    "prisma-json-types-generator": "^3.1.1",
    "redlock": "5.0.0-beta.2",
    "resend": "^4.0.1",
    "swagger-ui-express": "^4.6.3",
    "tsconfig-paths": "^4.2.0",
    "tsoa": "^6.5.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  }
}
