{
  "entryFile": "src/index.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "controllerPathGlobs": ["src/domains/**/routers.ts"],
  "spec": {
    "outputDirectory": "docs",
    "specVersion": 3,
    "yaml": true,
    "specFileBaseName": "api",
    "securityDefinitions": {
      "jwt": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "jwt"
      }
    }
  },
  "routes": {
    "routesDir": "src",
    "authenticationModule": "src/auth-middleware.ts"
  },
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["./src/lib/*"],
      "@domains/*": ["./src/domains/*"],
      "@static/*": ["./static/*"],
      "@types": ["./src/types"],
      "@*": ["./*"],
      "tsoa": ["node_modules/tsoa/dist"],
      "tsoa/": ["node_modules/tsoa/dist/"]
    }
  }
}
